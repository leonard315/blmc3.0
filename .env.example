# Copy this file to .env and fill values before running the app
# For Gmail with 2FA, create an App Password and use it here
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Optional: if using a custom SMTP provider, set HOST/PORT/SECURE
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
