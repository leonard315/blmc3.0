<!DOCTYPE html>
<html lang="en">
<head>
  {{> head}}
  <title>Sales History - BLMC POS</title>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50 min-h-screen antialiased flex">

<nav class="bg-white shadow-sm w-56 fixed h-full z-50 border-r border-gray-100 flex flex-col py-6 px-4 space-y-1 overflow-y-auto">
  <div class="flex items-center gap-3 mb-8 px-1">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-600 to-red-500 flex items-center justify-center shadow flex-shrink-0">
      <i data-lucide="shopping-cart" class="w-4 h-4 text-white"></i>
    </div>
    <div class="leading-tight">
      <p class="text-sm font-extrabold text-gray-900">BLMC POS</p>
      <p class="text-xs text-blue-500 font-semibold">Point of Sale</p>
    </div>
  </div>
  <a href="/pos/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard
  </a>
  <a href="/pos/sale" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="shopping-cart" class="w-4 h-4"></i> New Sale
  </a>
  <a href="/pos/sales-history" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-blue-50 text-blue-700 font-semibold text-sm">
    <i data-lucide="history" class="w-4 h-4"></i> Sales History
  </a>
  <a href="/pos/share-balance" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="piggy-bank" class="w-4 h-4"></i> Share Balance
  </a>
  <a href="/pos/patronage" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="percent" class="w-4 h-4"></i> Patronage Refund
  </a>
  <div class="mt-auto pt-4 border-t border-gray-100">
    <a href="/pos/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 font-semibold text-sm transition-colors">
      <i data-lucide="log-out" class="w-4 h-4"></i> Logout
    </a>
  </div>
</nav>

<div class="flex-1 ml-56 min-h-screen flex flex-col">
  <div class="bg-white border-b border-gray-100 px-8 py-4 sticky top-0 z-30 shadow-sm">
    <h1 class="text-2xl font-extrabold text-gray-900">Sales History</h1>
    <p class="text-xs text-gray-400 mt-0.5">All POS transactions</p>
  </div>

  <div class="p-8 flex-1">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
      {{#if sales.length}}
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="bg-gray-50 border-b border-gray-100">
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Date</th>
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Customer</th>
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Items</th>
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Payment</th>
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Total</th>
                <th class="px-5 py-3.5 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Status</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-50">
              {{#each sales}}
              <tr class="hover:bg-gray-50 transition-colors">
                <td class="px-5 py-3.5 text-xs text-gray-500">{{formatDate this.orderDate}}</td>
                <td class="px-5 py-3.5">
                  <p class="text-sm font-semibold text-gray-800">{{this.customerName}}</p>
                  {{#if this.customerId}}<p class="text-xs text-gray-400">{{this.customerId}}</p>{{/if}}
                </td>
                <td class="px-5 py-3.5 text-xs text-gray-500">{{this.itemCount}} item(s)</td>
                <td class="px-5 py-3.5">
                  <span class="text-xs font-bold px-2 py-1 rounded-full {{#if (eq this.paymentMethod 'cash')}}bg-green-100 text-green-700{{else}}bg-orange-100 text-orange-700{{/if}}">
                    {{this.paymentMethod}}
                  </span>
                </td>
                <td class="px-5 py-3.5 text-sm font-extrabold text-blue-600">{{formatCurrency this.total}}</td>
                <td class="px-5 py-3.5">
                  <span class="text-xs font-bold px-2 py-1 rounded-full {{#if (eq this.paymentStatus 'paid')}}bg-green-100 text-green-700{{else}}bg-yellow-100 text-yellow-700{{/if}}">
                    {{this.paymentStatus}}
                  </span>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      {{else}}
        <div class="p-16 text-center">
          <i data-lucide="inbox" class="w-10 h-10 text-gray-200 mx-auto mb-3"></i>
          <p class="text-sm text-gray-400">No sales recorded yet</p>
        </div>
      {{/if}}
    </div>
  </div>
</div>

<script>lucide.createIcons();</script>
</body>
</html>
