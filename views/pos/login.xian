<!DOCTYPE html>
<html lang="en">
<head>
  {{> head}}
  <title>POS Login - BLMC</title>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50 min-h-screen flex items-center justify-center antialiased">

  <div class="w-full max-w-sm">
    <!-- Logo -->
    <div class="text-center mb-8">
      <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-600 to-red-500 flex items-center justify-center mx-auto mb-4 shadow-lg">
        <i data-lucide="shopping-cart" class="w-8 h-8 text-white"></i>
      </div>
      <h1 class="text-2xl font-extrabold text-gray-900">BLMC Point of Sale</h1>
      <p class="text-sm text-gray-400 mt-1">Sign in to your POS account</p>
    </div>

    {{#if error_msg}}
      <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl mb-4">
        <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i> {{error_msg}}
      </div>
    {{/if}}

    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
      <form method="POST" action="/pos/login" class="space-y-4">
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Email</label>
          <div class="relative">
            <i data-lucide="mail" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
            <input type="email" name="email" required placeholder="Enter email"
              class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>
        <div>
          <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Password</label>
          <div class="relative">
            <i data-lucide="lock" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
            <input type="password" name="password" required placeholder="Enter password"
              class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
          </div>
        </div>
        <button type="submit"
          class="w-full bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-bold py-2.5 rounded-xl shadow hover:shadow-md transition-all text-sm mt-2">
          Sign In
        </button>
      </form>
    </div>

    <p class="text-center text-xs text-gray-400 mt-6">
      <a href="/login" class="hover:text-blue-600 transition-colors">Admin Login</a>
      &nbsp;·&nbsp;
      <a href="/member/login" class="hover:text-blue-600 transition-colors">Member Login</a>
      &nbsp;·&nbsp;
      <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
    </p>
  </div>

  <script>lucide.createIcons();</script>
</body>
</html>
