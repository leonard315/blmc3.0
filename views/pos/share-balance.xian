<!DOCTYPE html>
<html lang="en">
<head>
  {{> head}}
  <title>Share Balance - BLMC POS</title>
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.js"></script>
</head>
<body class="bg-gray-50 min-h-screen antialiased flex">

<!-- POS Sidebar -->
<nav class="bg-white shadow-sm w-56 fixed h-full z-50 border-r border-gray-100 flex flex-col py-6 px-4 space-y-1 overflow-y-auto">
  <div class="flex items-center gap-3 mb-8 px-1">
    <div class="w-9 h-9 rounded-xl bg-gradient-to-br from-blue-600 to-red-500 flex items-center justify-center shadow flex-shrink-0">
      <i data-lucide="shopping-cart" class="w-4 h-4 text-white"></i>
    </div>
    <div class="leading-tight">
      <p class="text-sm font-extrabold text-gray-900">BLMC POS</p>
      <p class="text-xs text-blue-500 font-semibold">Point of Sale</p>
    </div>
  </div>
  <a href="/pos/dashboard" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="layout-dashboard" class="w-4 h-4"></i> Dashboard
  </a>
  <a href="/pos/sale" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="shopping-cart" class="w-4 h-4"></i> New Sale
  </a>
  <a href="/pos/sales-history" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="history" class="w-4 h-4"></i> Sales History
  </a>
  <a href="/pos/share-balance" class="flex items-center gap-3 px-3 py-2.5 rounded-xl bg-blue-50 text-blue-700 font-semibold text-sm">
    <i data-lucide="piggy-bank" class="w-4 h-4"></i> Share Balance
  </a>
  <a href="/pos/patronage" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-gray-600 hover:bg-gray-50 font-semibold text-sm transition-colors">
    <i data-lucide="percent" class="w-4 h-4"></i> Patronage Refund
  </a>
  <div class="mt-auto pt-4 border-t border-gray-100">
    <a href="/pos/logout" class="flex items-center gap-3 px-3 py-2.5 rounded-xl text-red-500 hover:bg-red-50 font-semibold text-sm transition-colors">
      <i data-lucide="log-out" class="w-4 h-4"></i> Logout
    </a>
  </div>
</nav>

<!-- Main -->
<div class="flex-1 ml-56 min-h-screen flex flex-col">

  <div class="bg-white border-b border-gray-100 px-8 py-4 flex items-center justify-between sticky top-0 z-30 shadow-sm">
    <div>
      <h1 class="text-2xl font-extrabold text-gray-900">Share Balance</h1>
      <p class="text-xs text-gray-400 mt-0.5">Deposit, withdraw, and view patronage refund</p>
    </div>
    <span id="clock" class="text-xs text-gray-400 font-mono"></span>
  </div>

  <div class="p-8 flex-1">

    {{#if error_msg}}
      <div class="flex items-center gap-2 bg-red-50 border border-red-200 text-red-700 text-sm px-4 py-3 rounded-xl mb-4">
        <i data-lucide="alert-circle" class="w-4 h-4 shrink-0"></i> {{error_msg}}
      </div>
    {{/if}}
    {{#if success_msg}}
      <div class="flex items-center gap-2 bg-green-50 border border-green-200 text-green-700 text-sm px-4 py-3 rounded-xl mb-4">
        <i data-lucide="check-circle" class="w-4 h-4 shrink-0"></i> {{success_msg}}
      </div>
    {{/if}}

    <div class="grid grid-cols-1 xl:grid-cols-3 gap-6">

      <!-- LEFT: Member Search + Transaction Form -->
      <div class="xl:col-span-1 flex flex-col gap-4">

        <!-- Member Selector -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-3">Select Member</h3>
          <div class="relative">
            <i data-lucide="user" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400"></i>
            <input id="memberSearch" type="text" placeholder="Search member name or ID..."
              class="w-full pl-9 pr-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            <div id="memberDropdown" class="hidden absolute left-0 right-0 top-full mt-1 bg-white border border-gray-200 rounded-xl shadow-xl z-50 max-h-52 overflow-y-auto">
              <div id="memberList"></div>
            </div>
          </div>
          <!-- Selected member card -->
          <div id="selectedMemberCard" class="hidden mt-3 bg-blue-50 border border-blue-200 rounded-xl p-4">
            <div class="flex items-center justify-between mb-2">
              <p id="selName" class="text-sm font-extrabold text-blue-900"></p>
              <button onclick="clearMember()" class="text-blue-400 hover:text-red-500 transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
              </button>
            </div>
            <p id="selId" class="text-xs text-blue-500 mb-3"></p>
            <div class="grid grid-cols-2 gap-2">
              <div class="bg-white rounded-xl p-3 border border-blue-100 text-center">
                <p class="text-xs text-gray-400 font-semibold">Share Balance</p>
                <p id="selShare" class="text-lg font-extrabold text-blue-600 mt-0.5">₱0.00</p>
              </div>
              <div class="bg-white rounded-xl p-3 border border-blue-100 text-center">
                <p class="text-xs text-gray-400 font-semibold">Patronage Refund</p>
                <p id="selPatronage" class="text-lg font-extrabold text-green-600 mt-0.5">₱0.00</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Transaction Form -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-5">
          <h3 class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-4">Transaction</h3>
          <form method="POST" action="/pos/share-balance/transact" id="txForm">
            <input type="hidden" name="memberId" id="txMemberId">

            <!-- Type -->
            <div class="grid grid-cols-2 gap-2 mb-4">
              <button type="button" onclick="setTxType('deposit')" id="btn-deposit"
                class="tx-btn flex items-center justify-center gap-2 py-2.5 rounded-xl border-2 border-blue-500 bg-blue-50 text-blue-700 font-bold text-sm transition-all">
                <i data-lucide="arrow-down-circle" class="w-4 h-4"></i> Deposit
              </button>
              <button type="button" onclick="setTxType('withdraw')" id="btn-withdraw"
                class="tx-btn flex items-center justify-center gap-2 py-2.5 rounded-xl border-2 border-gray-200 text-gray-500 font-bold text-sm transition-all hover:border-gray-300">
                <i data-lucide="arrow-up-circle" class="w-4 h-4"></i> Withdraw
              </button>
            </div>
            <input type="hidden" name="txType" id="txType" value="deposit">

            <!-- Amount -->
            <div class="mb-4">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Amount (₱)</label>
              <input type="number" name="amount" id="txAmount" required min="1" step="0.01" placeholder="0.00"
                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            </div>

            <!-- Notes -->
            <div class="mb-4">
              <label class="block text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1.5">Notes (optional)</label>
              <input type="text" name="notes" placeholder="e.g. Monthly deposit"
                class="w-full px-4 py-2.5 rounded-xl border border-gray-200 text-sm bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" />
            </div>

            <button type="button" onclick="submitTx()"
              class="w-full inline-flex items-center justify-center gap-2 bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 text-white font-bold py-3 rounded-xl shadow hover:shadow-md transition-all text-sm">
              <i data-lucide="check-circle" class="w-4 h-4"></i> Process Transaction
            </button>
          </form>
        </div>

      </div>

      <!-- RIGHT: Recent Transactions -->
      <div class="xl:col-span-2 flex flex-col gap-4">

        <!-- Recent Share Transactions -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100">
            <h3 class="text-sm font-extrabold text-gray-900">Recent Share Transactions</h3>
          </div>
          {{#if recentTx.length}}
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="bg-gray-50 border-b border-gray-100">
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Date</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Member</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Type</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Amount</th>
                    <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wide">Balance After</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  {{#each recentTx}}
                  <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-5 py-3 text-xs text-gray-500">{{formatDate this.ledgerDate}}</td>
                    <td class="px-5 py-3 text-sm font-semibold text-gray-800">{{this.memberId}}</td>
                    <td class="px-5 py-3">
                      <span class="text-xs font-bold px-2 py-1 rounded-full {{#if (eq this.entryType 'credit')}}bg-green-100 text-green-700{{else}}bg-red-100 text-red-700{{/if}}">
                        {{#if (eq this.entryType 'credit')}}Deposit{{else}}Withdraw{{/if}}
                      </span>
                    </td>
                    <td class="px-5 py-3 text-sm font-extrabold {{#if (eq this.entryType 'credit')}}text-green-600{{else}}text-red-500{{/if}}">
                      {{#if (eq this.entryType 'credit')}}+{{else}}-{{/if}}{{formatCurrency this.amount}}
                    </td>
                    <td class="px-5 py-3 text-sm font-semibold text-gray-700">{{formatCurrency this.balance}}</td>
                  </tr>
                  {{/each}}
                </tbody>
              </table>
            </div>
          {{else}}
            <div class="p-12 text-center">
              <i data-lucide="inbox" class="w-10 h-10 text-gray-200 mx-auto mb-3"></i>
              <p class="text-sm text-gray-400">No share transactions yet</p>
            </div>
          {{/if}}
        </div>

      </div>
    </div>
  </div>
</div>

<script>
lucide.createIcons();
(function tick(){ const el=document.getElementById('clock'); if(el) el.textContent=new Date().toLocaleString('en-PH',{dateStyle:'medium',timeStyle:'short'}); setTimeout(tick,1000); })();

let allMembers = [], selectedMember = null, txType = 'deposit';

// Load all members
fetch('/api/members/all').then(r=>r.json()).then(d=>{ allMembers=d; }).catch(()=>{});

function renderMemberDropdown(members) {
  const dd = document.getElementById('memberDropdown');
  const list = document.getElementById('memberList');
  if (!members.length) {
    list.innerHTML = '<p class="text-xs text-gray-400 text-center py-3">No members found</p>';
  } else {
    list.innerHTML = members.map(m => `
      <button type="button" onclick='selectMember(${JSON.stringify(m)})'
        class="w-full text-left px-4 py-2.5 hover:bg-blue-50 transition-colors border-b border-gray-50 last:border-0">
        <p class="text-sm font-bold text-gray-800">${m.firstName} ${m.lastName}</p>
        <p class="text-xs text-gray-400">${m.memberId} · Share: ₱${parseFloat(m.shareBalance||0).toFixed(2)} · Patronage: ₱${parseFloat(m.patronageRefundAccrued||0).toFixed(2)}</p>
      </button>
    `).join('');
  }
  dd.classList.remove('hidden');
}

document.getElementById('memberSearch').addEventListener('focus', function() {
  renderMemberDropdown(allMembers);
});
document.getElementById('memberSearch').addEventListener('input', function() {
  const q = this.value.trim().toLowerCase();
  renderMemberDropdown(q ? allMembers.filter(m =>
    (m.firstName+' '+m.lastName).toLowerCase().includes(q) || m.memberId.toLowerCase().includes(q)
  ) : allMembers);
});
document.addEventListener('click', e => {
  if (!e.target.closest('#memberSearch') && !e.target.closest('#memberDropdown'))
    document.getElementById('memberDropdown').classList.add('hidden');
});

function selectMember(m) {
  selectedMember = m;
  document.getElementById('memberSearch').value = '';
  document.getElementById('memberDropdown').classList.add('hidden');
  document.getElementById('txMemberId').value = m.memberId;
  document.getElementById('selName').textContent = m.firstName + ' ' + m.lastName;
  document.getElementById('selId').textContent = m.memberId;
  // Show card immediately with cached data
  document.getElementById('selShare').textContent = '₱' + parseFloat(m.shareBalance||0).toFixed(2);
  document.getElementById('selPatronage').textContent = '₱' + parseFloat(m.patronageRefundAccrued||0).toFixed(2);
  document.getElementById('selectedMemberCard').classList.remove('hidden');
  // Fetch live data to update balances in real-time
  fetch('/api/members/detail/' + encodeURIComponent(m.memberId))
    .then(r => r.json())
    .then(live => {
      selectedMember = { ...selectedMember, ...live };
      document.getElementById('selShare').textContent = '₱' + parseFloat(live.shareBalance||0).toFixed(2);
      document.getElementById('selPatronage').textContent = '₱' + parseFloat(live.patronageRefundAccrued||0).toFixed(2);
    })
    .catch(() => {});
}

function clearMember() {
  selectedMember = null;
  document.getElementById('selectedMemberCard').classList.add('hidden');
  document.getElementById('txMemberId').value = '';
  document.getElementById('memberSearch').value = '';
}

// Auto-refresh selected member balance every 5 seconds
setInterval(() => {
  if (!selectedMember) return;
  fetch('/api/members/detail/' + encodeURIComponent(selectedMember.memberId))
    .then(r => r.json())
    .then(live => {
      selectedMember = { ...selectedMember, ...live };
      document.getElementById('selShare').textContent = '₱' + parseFloat(live.shareBalance||0).toFixed(2);
      document.getElementById('selPatronage').textContent = '₱' + parseFloat(live.patronageRefundAccrued||0).toFixed(2);
    })
    .catch(() => {});
}, 5000);

function setTxType(type) {
  txType = type;
  document.getElementById('txType').value = type;
  document.querySelectorAll('.tx-btn').forEach(b => {
    b.classList.remove('border-blue-500','bg-blue-50','text-blue-700','border-red-400','bg-red-50','text-red-700');
    b.classList.add('border-gray-200','text-gray-500');
  });
  const active = document.getElementById('btn-' + type);
  if (type === 'deposit') {
    active.classList.add('border-blue-500','bg-blue-50','text-blue-700');
  } else {
    active.classList.add('border-red-400','bg-red-50','text-red-700');
  }
  active.classList.remove('border-gray-200','text-gray-500');
}

function submitTx() {
  if (!selectedMember) { alert('Please select a member first.'); return; }
  const amount = parseFloat(document.getElementById('txAmount').value);
  if (!amount || amount <= 0) { alert('Please enter a valid amount.'); return; }
  if (txType === 'withdraw' && amount > parseFloat(selectedMember.shareBalance||0)) {
    alert('Insufficient share balance for withdrawal.'); return;
  }
  document.getElementById('txForm').submit();
}
</script>
</body>
</html>
